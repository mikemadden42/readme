#
# avoid sudo for global installs by setting a per-user prefix:
mkdir -p ~/.npm-global
npm config set prefix ~/.npm-global
echo 'export PATH=~/.npm-global/bin:$PATH' >> ~/.zshrc
exec zsh
#
# update: `npm update -g @anthropic-ai/claude-code`


# 3. HOMEBREW ON LINUX (only if already using brew)
brew install anthropic/claude/claude-code


# AUTH — two modes

# subscription (Pro / Max) — usual choice for individual use:
