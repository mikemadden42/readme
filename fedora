# LOW-LATENCY TUNING

# pipewire uses QUANTUM (buffer size in samples) and RATE (sample
# rate Hz). lower quantum = lower latency = more CPU.
#
# inspect / change at runtime:
pw-metadata -n settings 0 clock.force-quantum 256       # 256 samples
pw-metadata -n settings 0 clock.force-rate 48000        # 48 kHz
pw-metadata -n settings 0 clock.force-quantum 0         # back to auto

# persistent config — drop in /etc/pipewire/pipewire.conf.d/:
sudo tee /etc/pipewire/pipewire.conf.d/99-lowlatency.conf <<'EOF'
context.properties = {
  default.clock.rate          = 48000
  default.clock.quantum       = 512
  default.clock.min-quantum   = 256
  default.clock.max-quantum   = 1024
}
EOF
systemctl --user restart pipewire pipewire-pulse

# typical latencies:
#   quantum 1024 / 48k = ~21ms — desktop, browsers, video
#   quantum 512 / 48k  = ~10ms — gaming, general production
#   quantum 256 / 48k  = ~5ms  — live performance, vocals
#   quantum 64 / 48k   = ~1ms  — pro audio (needs RT kernel realistically)


# COMMON GOTCHAS

# 1. AUDIO GONE AFTER SUSPEND. usually wireplumber lost the device.
#    fix:
systemctl --user restart wireplumber pipewire pipewire-pulse
#    if persistent, check `journalctl --user -u pipewire -b -1` for
#    the suspend / resume transition.
#
# 2. PER-APP VOLUME STICKS AT WRONG VALUE. state lives in
#    ~/.local/state/wireplumber/. delete the relevant restore file
#    and reset:
rm -rf ~/.local/state/wireplumber/
systemctl --user restart wireplumber
#
# 3. HDMI AUDIO MISSING. HDMI sink only appears when a display is
#    attached at pipewire start. plug HDMI, then:
systemctl --user restart wireplumber
#
# 4. BLUETOOTH HEADPHONES KEEP DISCONNECTING. usually BlueZ +
#    PipeWire ordering issue or power-save on the bluetooth radio.
#    workaround:
sudo tee /etc/modprobe.d/bluetooth-powersave.conf <<'EOF'
options btusb enable_autosuspend=0
EOF
sudo dracut --force
#
# 5. THE WRONG SINK BECAME DEFAULT after plugging in USB headphones.
#    wireplumber should auto-switch but doesn't always. force:
wpctl set-default <new-id>
#    persistent: WirePlumber's "default-policy" config controls auto-
#    switch behavior. in /etc/wireplumber/main.lua.d/.
#
# 6. PIPEWIRE VS ALSA LOOPBACK for recording system audio. the modern
#    way is pavucontrol → Recording tab → pick "Monitor of <output>"
#    for an app like OBS. or pw-link the output's monitor port to
#    OBS's input.
#
# 7. APPS USING "snd_aloop" KERNEL MODULE WON'T SEE PIPEWIRE STREAMS.
#    they're talking to raw ALSA. either redirect via pw-link or
#    configure the app to use the pulseaudio API.


# DECISION MATRIX — WHICH TOOL FOR WHAT

#   "set my volume / mute / default"           → wpctl
#   "GUI mixer with per-app control"           → pavucontrol
#   "visualize the audio graph"                → qpwgraph / helvum
#   "noise-cancel my mic for calls"            → EasyEffects
#   "low-latency for music production"         → pw-jack + tuned quantum
#   "force a bluetooth codec"                  → wireplumber config
#   "route firefox to bluetooth manually"      → pw-link
#   "old pulseaudio script needs to work"      → pactl (still works)


