VIRTUAL MACHINES
----------------

# fedora has good libvirt + KVM + QEMU support out of the box. the
# "which tool" question depends on how much control you want:
#
#   gnome-boxes           — easiest. fewest clicks, OS catalog, minimal
#                           config. great for "try this ISO for an
#                           afternoon". no snapshots / custom networks /
#                           passthrough in the GUI.
#   virt-manager          — full libvirt GUI. snapshots, custom networks,
#                           USB / PCI passthrough, NUMA, complex storage.
#                           the power-user default.
#   cockpit + cockpit-machines — web UI at https://localhost:9090. best
#                           for headless hosts or browser-driven mgmt.
#   virsh / virt-install  — canonical CLI. scriptable, reproducible. the
#                           right answer for "define this VM in a file
#                           i can commit to git".
#   vagrant + vagrant-libvirt — declarative Vagrantfile, `vagrant up`.
#                           great for reproducible dev environments.
#                           see [[vagrant]].
#   distrobox / toolbox   — NOT VMs. containers that look like a full
#                           alternate linux userspace. share your /home,
#                           GPU, network. usually the right answer when
#                           the real question is "i want a different
#                           distro environment for a task", not "i need
#                           full isolation".


# RECOMMENDED INSTALL — both GUIs share the libvirt backend, VMs
# created in one show up in the other:
sudo dnf install gnome-boxes virt-manager libvirt qemu-kvm virt-viewer \
    libguestfs-tools libosinfo

# permissions: enable libvirtd, add yourself to the libvirt group so
# you don't need sudo for per-user operations:
sudo systemctl enable --now libvirtd
sudo usermod -aG libvirt "$USER"
# log out and back in (or `newgrp libvirt`) for the group to take effect.


# KVM HARDWARE CHECK — confirm hardware virt is on
lscpu | grep -E 'Virtualization|vmx|svm'      # vmx = intel, svm = amd
ls -l /dev/kvm                                # should exist + be readable
                                              # by your user (via the kvm group)

# if /dev/kvm is missing, virt is disabled in firmware (Intel VT-x /
# AMD-V). enable it in BIOS/UEFI and reboot.

# nested virt (run VMs inside VMs — useful for testing virt-stacks):
cat /sys/module/kvm_intel/parameters/nested   # should be Y
# enable persistently if N:
echo 'options kvm_intel nested=1' | sudo tee /etc/modprobe.d/kvm.conf
sudo modprobe -r kvm_intel && sudo modprobe kvm_intel


# virsh — DAILY COMMANDS

virsh list --all                              # every VM, running or off
virsh start fedora-test
virsh shutdown fedora-test                    # graceful (ACPI)
virsh destroy fedora-test                     # power off (force, no save)
virsh reboot fedora-test
virsh suspend fedora-test                     # pause to RAM
virsh resume fedora-test
virsh console fedora-test                     # serial console (Ctrl+] to exit)
virsh edit fedora-test                        # edit the libvirt XML
virsh dumpxml fedora-test > fedora-test.xml   # back up the config
virsh net-list --all                          # libvirt networks


# virt-install — scripted VM creation from an ISO

sudo virt-install \
    --name fedora-test \
    --memory 4096 \
    --vcpus 4 \
    --disk size=40,format=qcow2 \
    --cdrom ~/Downloads/Fedora-Workstation-Live-x86_64-44.iso \
    --os-variant fedora44 \
    --graphics spice \
    --network network=default

# list known --os-variant values
osinfo-query os | grep -i fedora


# SNAPSHOTS — only on qcow2 disks, not raw

# external (preferred for production) — disk file shared, RAM separate.
virsh snapshot-create-as fedora-test pre-experiment \
    --description "before kernel test" --atomic
virsh snapshot-list fedora-test
virsh snapshot-revert fedora-test pre-experiment
virsh snapshot-delete fedora-test pre-experiment


# WINDOWS GUESTS — virtio drivers

# windows doesn't ship virtio drivers natively. install with the
# fedoraproject virtio-win ISO mounted as a second cdrom:
sudo dnf install virtio-win
ls /usr/share/virtio-win/                     # the ISO + per-driver dirs
# inside the windows installer, "load driver" → point at the virtio-win
# CD → pick viostor (storage) and netkvm (network).
# the spice-guest-tools msi installs everything else (clipboard, display
# resize, etc.).


# DISTROBOX / TOOLBOX — when you don't actually need a full VM

# toolbox is fedora's own (uses podman + fedora-toolbox image):
toolbox create -c f44-tools                   # default: matches host fedora
toolbox enter f44-tools
toolbox rm f44-tools

# distrobox is the more flexible tool — any distro image, with home /
# audio / x / wayland passthrough configured automatically:
sudo dnf install distrobox
distrobox create -n ubuntu24 -i docker.io/library/ubuntu:24.04
distrobox enter ubuntu24
distrobox list
distrobox rm ubuntu24

# common pattern: distrobox for "I want pacman / apt for this one
# task" without giving up your fedora host. the host's gpu, /home,
# and pulse/pipewire are already there.


# GPU PASSTHROUGH (advanced)

# single-GPU passthrough on linux is doable but messy (you give up the
# GPU to the VM and use a second one or ssh in). dual-GPU + IOMMU is
# the supportable path. the fedora wiki and arch wiki both have
# extensive guides — start there rather than improvising.
# preconditions: VT-d / AMD-Vi enabled in firmware, distinct iommu
# groups for the GPU, vfio-pci binding.
lscpu | grep -i 'virtualization'
dmesg | grep -i iommu                         # look for "IOMMU enabled"
ls /sys/kernel/iommu_groups/                  # one dir per group


# WHICH ONE SHOULD YOU INSTALL?
#
#   "i want to try this ISO"                 → gnome-boxes
#   "i want to run a windows VM long-term"   → virt-manager
#   "i want a reproducible dev env"          → distrobox, then vagrant
#   "i want to run apt for one task"         → distrobox / toolbox
#   "i want to script VM provisioning"       → virsh + virt-install
#   "i want browser-driven VM mgmt"          → cockpit-machines
#   "i want GPU passthrough"                 → virt-manager + reading


COCKPIT — WEB-BASED SYSTEM ADMINISTRATION
-----------------------------------------

# cockpit is fedora's blessed web UI for system administration. think
# of it as "a browser-based version of the operations the SYSTEMD,
# NETWORKING, and STORAGE sections cover via CLI". listens on
# https://localhost:9090. backed by D-Bus + systemd + NetworkManager
# + firewalld, so it's a thin UI layer over the same operations CLI
# does.


# WHAT COCKPIT IS — AND ISN'T

# IS:
#   - a session-based web UI for admin tasks
#   - a unified pane covering services, networking, accounts, storage,
#     logs, software updates, containers, VMs
#   - a federation point for managing MULTIPLE machines from one
#     cockpit instance
#   - extensible — third-party modules exist (cockpit-podman,
#     cockpit-machines, cockpit-storaged, cockpit-389-ds, etc.)
#
# IS NOT:
#   - a long-running daemon doing background work (it's started
#     on-demand by systemd socket activation)
#   - a replacement for ansible / puppet / chef (it's interactive,
#     not declarative)
#   - automation-friendly (no formal API; intended for humans)


# INSTALL + FIRST RUN

# the core + the modules you'll actually use:
sudo dnf install cockpit \
    cockpit-system \
    cockpit-networkmanager \
    cockpit-storaged \
    cockpit-podman \
    cockpit-machines \
    cockpit-selinux \
    cockpit-packagekit

# enable the socket (started on-demand by socket activation; cheap):
sudo systemctl enable --now cockpit.socket

# open firewalld for it (default: only loopback; you usually want LAN):
sudo firewall-cmd --add-service=cockpit --permanent && \
    sudo firewall-cmd --reload

# access:
#   https://localhost:9090       (from this machine)
#   https://<host>.local:9090     (from your LAN)
# log in as any user in the `wheel` group (sudoers); cockpit uses PAM.

# first-time TLS warning: cockpit ships an auto-signed cert. accept it
# in the browser, or install your own (next section).


# THE STANDARD MODULES

#   OVERVIEW          — system summary, CPU/memory/disk graphs over time,
#                       uptime, recent events, hardware info
#   LOGS              — journalctl browser with filters (priority, unit,
#                       time range). good for "show me errors since today"
#   NETWORKING        — interfaces, bonds, bridges, VLANs (NetworkManager
#                       under the hood). firewalld zones + services.
#   ACCOUNTS          — local user / group management, SSH key install
#   SERVICES          — start/stop/enable/disable systemd units; mask;
#                       view properties. the GUI version of `systemctl`.
#   SOFTWARE UPDATES  — runs `dnf upgrade` with progress UI. shows
#                       security updates separately.
#   STORAGE           — disks, partitions, LVM, btrfs, NFS mounts.
#                       create / resize / format / encrypt.
#   TERMINAL          — embedded web terminal (real shell, no SSH client
#                       needed). useful for "i need CLI but I'm already
#                       in cockpit".
#   CONTAINERS        — cockpit-podman: list / start / stop containers,
#                       inspect images, build from Containerfile.
#   VIRTUAL MACHINES  — cockpit-machines: libvirt frontend (covered in
#                       VIRTUAL MACHINES section).
#   SELINUX           — view denials, modify booleans, browse policy
#                       (the GUI version of the SELINUX section's
#                       `audit2allow` workflow).
#   DIAGNOSTIC REPORTS — `sosreport` generation (the standard "send this
#                        to red hat support" tarball)
#   APPLICATIONS      — application-specific modules (3rd party plugin
#                       discovery)


# REMOTE MACHINE MANAGEMENT (FEDERATION)

# cockpit can manage REMOTE machines from one UI. login to your local
# cockpit, click the hostname dropdown, "Add new host":
#   - enter hostname + ssh user
#   - cockpit ssh's to the remote, installs nothing
#   - the remote needs cockpit installed too, OR cockpit-bridge alone
#     (much lighter)
#
# the experience: switch between hosts from a dropdown; manage each
# with the full UI. designed for small fleets (5-20 machines); larger
# fleets want ansible AWX or similar.


# TLS / CERTIFICATES

# cockpit ships a self-signed cert at /etc/cockpit/ws-certs.d/0-self-
# signed.cert. for LAN use:
#   - accept the warning in the browser (one-time per machine)
#   - or import the cert into your browser's trust store
#
# for proper TLS (your own CA or let's encrypt):
sudo cp ~/my-fullchain.pem /etc/cockpit/ws-certs.d/10-mycert.cert
sudo cp ~/my-key.pem /etc/cockpit/ws-certs.d/10-mycert.key
sudo chmod 600 /etc/cockpit/ws-certs.d/10-mycert.key
sudo systemctl restart cockpit.socket cockpit


# AUTHENTICATION

# cockpit defaults to local PAM (your linux password). additional options:
#   - SSH key — if your account has authorized_keys, the embedded
#     terminal uses them automatically
#   - certificates — client cert auth via /etc/cockpit/cockpit.conf
#   - kerberos / GSSAPI — for Active Directory / IPA environments
#
# tune in /etc/cockpit/cockpit.conf:
sudo tee /etc/cockpit/cockpit.conf <<'EOF'
[WebService]
LoginTo = false                # disable "log in to another machine" UI
AllowUnencrypted = false       # require HTTPS (default true on localhost)
MaxStartups = 10               # concurrent login attempts
EOF
sudo systemctl restart cockpit.socket


# SELINUX + FIREWALLD

# cockpit's policy is shipped; selinux works out of the box. denials
# usually mean a custom path or port (covered in SELINUX — GOING DEEPER).
# firewalld has a preconfigured `cockpit` service:
sudo firewall-cmd --info-service=cockpit


# EXTENDING — WRITING A COCKPIT MODULE (advanced)

# cockpit modules are HTML + JS apps that run inside the cockpit shell.
# the cockpit project documents the API:
#   https://cockpit-project.org/guide/latest/
#
# a minimal module is a directory under ~/.local/share/cockpit/<name>/
# with a manifest.json. dev iteration is fast; deploy is just copying
# files. niche but useful for in-house tooling.


# WHEN COCKPIT BEATS SSH + CLI

# good for:
#   - VISUALIZATIONS over time (CPU / memory / network graphs)
#   - less-experienced team members ("just open cockpit and look at
#     the services tab")
#   - audit / single-pane-of-glass for someone overseeing N machines
#   - quick diagnostics ("is this VM healthy" — open cockpit, glance)
#   - homelab use where you want a browser UI for casual tasks
#
# bad for:
#   - scripting / automation (no formal API; intended for humans)
#   - complex multi-step operations (CLI / ansible is better)
#   - large fleets (>50 machines — federation gets unwieldy)
#   - hands-off / unattended operations


# HONEST TRADEOFFS

# 1. FEATURE PARITY WITH CLI VARIES. some operations have no UI; the
#    embedded terminal is the escape hatch.
# 2. SHIPS WITH FEDORA SERVER + WORKSTATION + ATOMIC. on minimal
#    installs you may need to install + open firewall.
# 3. NO API. you can't automate cockpit operations — it's interactive
#    by design.
# 4. BROWSER COMPAT. modern browsers only; some older firefox versions
#    have CSS quirks. modern chrome / firefox are fine.
# 5. THE REMOTE-HOST DROPDOWN DOESN'T SCALE. great for 5 hosts; ugly
#    at 50.


# DECISION MATRIX

#   "homelab admin from my laptop browser"      → cockpit
#   "i need a web GUI for the NAS / mini-PC"    → cockpit
#   "i'm onboarding a junior to sysadmin"       → cockpit (familiar UI)
#   "i want to automate provisioning"           → ansible, NOT cockpit
#   "i want to manage 100+ machines"            → ansible + AWX, not
#                                                  cockpit
#   "VMs on this fedora box"                    → cockpit-machines
#   "containers on this fedora box"             → cockpit-podman
#   "audit dashboard for a small team"          → cockpit federation


CONTAINERS — PODMAN FIRST
-------------------------

# fedora ships PODMAN as the blessed container engine, not docker.
# docker was removed from fedora repos in F31 (cgroups v2 conflict at
# the time; long since resolved, but red hat moved to podman). podman
# is daemonless and rootless-by-default — two real wins over docker on
# a personal machine:
#
#   - no `dockerd` running as root, no socket to secure, no `docker`
#     group with effective-root power.
#   - containers run as YOUR user via user namespaces. the classic
#     "added myself to the docker group and now my container can mount
#     /" escalation doesn't exist.
#
# podman's CLI is docker-compatible — every `docker <verb>` has a
# matching `podman <verb>`. most tutorials work verbatim.


# DAY-ONE INSTALL
sudo dnf install podman podman-compose podman-docker buildah skopeo
#   - podman           — the engine + CLI
#   - podman-compose   — python wrapper that reads docker-compose.yml
#   - podman-docker    — installs /usr/bin/docker as a symlink to podman
#                        so copy-pasted `docker ...` commands work
#   - buildah          — image builder (more flexible than `podman build`)
#   - skopeo           — inspect / copy images across registries without
#                        pulling them locally

# verify rootless works:
podman info | grep -iE 'rootless|graphRoot'
podman run --rm hello-world


# DAILY COMMANDS (docker-compatible)

podman run -it --rm -v "$PWD":/work fedora:44 bash   # one-off interactive
podman run -d --name web -p 8080:80 nginx           # detached, name + port
podman ps                                           # running containers
podman ps -a                                        # all (including stopped)
podman images                                       # local image cache
podman logs -f web                                  # follow container logs
podman exec -it web bash                            # shell into a container
podman stop web && podman rm web                    # stop + remove
podman rmi nginx                                    # remove an image
podman system prune -af                             # nuke unused (CAREFUL)


# BUILDING IMAGES

# from a Containerfile (or Dockerfile — podman accepts either name):
podman build -t myapp:dev .

# multi-arch build (useful with cross-platform deploys):
podman build --platform linux/amd64,linux/arm64 -t myapp:dev .

# buildah for fine-grained / scripted image construction:
buildah from fedora:44
# (returns a working container; modify it with `buildah run`, then
#  `buildah commit` to produce the image. cleaner than Containerfile
#  for highly-conditional builds.)


# COMPOSE — three options

# 1. podman-compose (python wrapper, simplest path):
podman-compose -f docker-compose.yml up -d

# 2. `podman compose` (subcommand, since 4.1) — finds podman-compose or
#    docker-compose and wraps it. one less command to remember:
podman compose up -d

# 3. QUADLET — podman's native systemd integration, no compose at all.
#    write a .container unit file in ~/.config/containers/systemd/
#    and systemd manages the lifecycle. cleanest path for long-running
#    services.

mkdir -p ~/.config/containers/systemd
cat >~/.config/containers/systemd/web.container <<'EOF'
[Unit]
Description=nginx via podman quadlet

[Container]
Image=docker.io/library/nginx:latest
PublishPort=8080:80
Volume=%h/www:/usr/share/nginx/html:Z

[Service]
Restart=always

[Install]
WantedBy=default.target
EOF
systemctl --user daemon-reload
systemctl --user enable --now web.service        # quadlet derives the unit name


# REGISTRIES — fedora's default search list

# podman searches multiple registries by default. config at
# /etc/containers/registries.conf — fedora preconfigures registry.fedoraproject.org,
# registry.access.redhat.com, docker.io, and quay.io. that's why bare
# image names (e.g. `nginx`) just work without the docker.io/ prefix.
podman search nginx                              # tries all configured registries

# disable a registry temporarily by using the fully-qualified name:
podman run docker.io/library/nginx               # explicit


# WHEN TO REACH FOR DOCKER INSTEAD

# - a workflow REQUIRES the docker daemon socket (testcontainers, some
#   IDE integrations, docker-in-docker CI runners that hard-code
#   `unix:///var/run/docker.sock`).
# - shared docker-compose.yml using docker-specific extensions you
#   can't change.
# - team / corp standardization on docker.
#
# install path (note: external repo, extra trust surface):
sudo dnf -y install dnf-plugins-core
sudo dnf config-manager addrepo --from-repofile=https://download.docker.com/linux/fedora/docker-ce.repo
sudo dnf install docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
sudo systemctl enable --now docker
sudo usermod -aG docker "$USER"      # log out and back in
# don't install both podman and docker as root daemons casually —
# they'll fight over /var/lib/cni and iptables rules. if you need
# both, run docker rootless or pick one.


# CONTAINER-AS-DEV-SHELL (covered in VMs section)

# distrobox and toolbox both run on podman. when you want "I need apt
# for this one task" without giving up your fedora host, use those
# rather than spinning up a long-lived podman container — they handle
# /home, GPU, audio, x/wayland passthrough for you.


# WHICH ONE FOR WHAT
#
#   "i want to run nginx as a service"        → podman + quadlet
#   "i want to follow a docker tutorial"      → podman + podman-docker
#   "i have a docker-compose.yml"             → podman-compose
#   "i need testcontainers / DinD CI"         → docker
#   "i want a long-lived dev environment"     → distrobox (see VMs)
#   "i want to build multi-arch images"       → podman build --platform
#   "i want to inspect a registry image"      → skopeo inspect


SILVERBLUE / IMMUTABLE FEDORA
-----------------------------

# fedora's immutable workstation family. silverblue (GNOME) is the
# flagship; kinoite (KDE), sericea (sway), and onyx (budgie) are
# siblings. the FUTURE TRENDS section names this family as where
# "fedora" likely converges by 2030 — this section is the depth.


# THE MODEL — IMAGE-BASED, ATOMIC, REVERSIBLE

# silverblue swaps fedora's traditional package-by-package mutability
# for IMAGE-BASED DEPLOYMENTS. the OS is shipped as a complete tree
# downloaded atomically. core invariants:
#
#   - /usr is READ-ONLY at runtime. you cannot `dnf install`. cannot
#     edit /usr files. immutable.
#   - /etc is writable. config changes persist. on upgrade, merged
#     intelligently with the new base.
#   - /var is writable. logs, container images, /var/home (symlinked
#     from /home), databases. persists across upgrades.
#   - DEPLOYMENTS are versioned and side-by-side. upgrading downloads
#     a new tree ALONGSIDE the current one. you reboot into the new
#     tree; if it breaks, reboot into the old one.
#   - ROLLBACK IS A REBOOT. literally — pick the previous deployment
#     from grub.
#   - rpm-ostree is the package manager. yum / dnf are not used on
#     the host.
#
# ostree under the hood: deployments live under /ostree/deploy/. think
# of it as git for filesystem trees — content-addressed, dedup'd,
# atomic switches between references. similar concept to the nix store
# but image-based rather than per-package.


# THE VARIANTS

#   Silverblue  — GNOME on wayland. flagship, most resourced.
#   Kinoite     — KDE Plasma. official Edition since F35.
#   Sericea     — Sway compositor. official since F37.
#   Onyx        — Budgie. official since F39.
#
# all share the rpm-ostree base and tooling. only the DE + default
# flatpak bundle differs.


# rpm-ostree — DAILY COMMANDS

# inspect current state
rpm-ostree status                              # current + pending deployments
rpm-ostree status -v                           # verbose (commit hashes)

# upgrade — downloads new base, stages as pending deployment
rpm-ostree upgrade
sudo systemctl reboot                          # boot into the new deployment

# preview / check without applying
rpm-ostree upgrade --preview
rpm-ostree upgrade --check

# rollback — make the PREVIOUS deployment the default for next boot
rpm-ostree rollback
sudo systemctl reboot

# diff between current and another deployment
rpm-ostree db diff


# LAYERING — PACKAGES ON THE BASE

# some software MUST be in /usr — kernel modules, drivers, anything
# that needs to run before flatpak / toolbox starts. layer it:
rpm-ostree install fish
sudo systemctl reboot

# remove a layered package
rpm-ostree uninstall fish

# apply live (avoid reboot, where safe)
rpm-ostree install --apply-live fish

# WARNING: layered packages slow upgrades. each upgrade rebuilds the
# deployment with your layers re-applied. KEEP LAYERS MINIMAL — only
# what truly cannot live in flatpak or toolbox.

# override / replace base packages
rpm-ostree override replace ./fixed-kernel.rpm
rpm-ostree override remove kernel-modules-extra

# reset all overlays / overrides
rpm-ostree reset

# kernel arguments
rpm-ostree kargs --append="nosmt"
rpm-ostree kargs --delete="quiet"
rpm-ostree kargs                               # show current


# THE INSTALL DECISION TREE

# silverblue users develop a habit. for any new piece of software:
#
#   1. desktop APP? → FLATPAK first. flathub covers most popular apps.
#      sandboxed. portable across atomic distros. zero impact on base.
#
#   2. CLI / dev tool you'd use interactively? → TOOLBOX or DISTROBOX.
#      enter a mutable container, dnf install there. host stays pristine.
#
#   3. SERVICE (a daemon you want running)? → PODMAN QUADLET (see
#      CONTAINERS section). systemd manages a containerized service.
#
#   4. needs to BE IN /USR (kernel module, driver, login shell for the
#      host, anything pre-session)? → only THEN `rpm-ostree install`.
#
# fewer than 10 layered packages on a typical silverblue install is
# normal. host minimal; dev work in containers; apps in flatpaks.


# TOOLBOX — THE MANDATORY DEV ENVIRONMENT

# on workstation, toolbox is optional. on silverblue it's effectively
# REQUIRED for dev work — you can't `dnf install gcc` on the host.

# create a toolbox matching the host fedora release
toolbox create -c f44

# enter it
toolbox enter f44

# inside the toolbox: dnf install whatever you want
sudo dnf install gcc cmake make ripgrep neovim

# /home is shared host ↔ toolbox. /usr inside the toolbox is mutable;
# the host's /usr is not.

# cross-distro dev — a toolbox for each distro you need
toolbox create -c ubuntu --image docker.io/library/ubuntu:24.04
distrobox create -n arch -i docker.io/library/archlinux:latest

# common pattern: one toolbox per language stack, or per distro for
# cross-platform package testing.


# SILVERBLUE-SPECIFIC GOTCHAS

# 1. NVIDIA proprietary driver. path differs from workstation. enable
#    RPM Fusion as layered packages first, then install akmod-nvidia:
rpm-ostree install \
    https://mirrors.rpmfusion.org/free/fedora/rpmfusion-free-release-$(rpm -E %fedora).noarch.rpm \
    https://mirrors.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-$(rpm -E %fedora).noarch.rpm
sudo systemctl reboot
rpm-ostree install akmod-nvidia xorg-x11-drv-nvidia-cuda
sudo systemctl reboot
#    easier path: rebase to a uBlue variant that preconfigures nvidia
#    (uCore-nvidia, Bazzite-nvidia, Bluefin-nvidia).
#
# 2. /USR/LOCAL IS A SYMLINK to /var/usrlocal. drop scripts into
#    /var/usrlocal/bin/ — or use ~/.local/bin (preferred).
#
# 3. SYSTEM-WIDE CONFIGS outside /etc and /var don't survive upgrades.
#    everything outside those two trees is part of the image.
#
# 4. UNLAYER BEFORE REPORTING BUGS. `rpm-ostree reset` and reboot to
#    confirm it's not your layers.
#
# 5. /BOOT IS MANAGED BY OSTREE. don't edit grub.cfg directly. use
#    `rpm-ostree kargs` instead.
#
# 6. DKMS DOESN'T WORK. use akmods (rpm-ostree handles it) or bake
#    the module into a custom image (uBlue-style).
#
# 7. SERVICES INSTALLED VIA `rpm-ostree install` run as system
#    services; their config goes in /etc/. for app-style services,
#    prefer QUADLET over layered rpms — keeps the base lean.
#
# 8. GNOME EXTENSIONS install fine (per-user, no /usr writes).


# WHEN TO PICK SILVERBLUE OVER WORKSTATION

# pick silverblue when:
#   - you want unbrickable updates with one-click rollback
#   - your dev workflow can live in containers (most modern workflows can)
#   - you're tired of config drift — machines diverging subtly from a
#     fresh install over time
#   - you want to share / sync your setup as an image (uBlue-style)
#   - you self-host services and prefer them containerized anyway

# stay on workstation when:
#   - you actively run kernel-mode tooling that needs DKMS
#   - your work requires layering many packages that don't fit
#     flatpak / toolbox (research, niche scientific stacks)
#   - you prefer imperative system mutation
#   - you use rpm-ostree-incompatible workflows (custom-compiled
#     kernel patches, hand-built /usr installs)

# the population that thrives on silverblue: developers running
# containerized stacks, users who appreciate stability, anyone who's
# been burned by a bad upgrade and wants atomic rollback as a default.


# UBLUE / PROJECT BLUEFIN / BAZZITE — OPINIONATED SILVERBLUE

# the uBlue ("Universal Blue") family is community-maintained atomic
# fedora derivatives with sensible defaults pre-baked. they fix
# silverblue's biggest practical gripes — nvidia, codecs, common
# tools — by shipping pre-built images rather than asking you to
# layer them yourself.
#
#   - PROJECT BLUEFIN — silverblue + developer tooling (vscode,
#     devcontainer support, just commands). "the new linux laptop for
#     cloud-native developers".
#   - BAZZITE        — silverblue + gaming stack (steam, proton-ge,
#     gamescope, mangohud). steamOS-style desktop on AMD or NVIDIA.
#   - UCORE          — silverblue minimal + nvidia + codecs prebaked.
#     a clean base to build your own image from.
#   - AURORA         — kinoite-based bluefin (KDE).
#
# install path is "rebase to a uBlue image":
sudo rpm-ostree rebase ostree-image-signed:docker://ghcr.io/ublue-os/bluefin:latest
sudo systemctl reboot
# you're now running bluefin instead of stock silverblue. rebase back
# any time. the machinery is the same.


# THE BROADER ATOMIC LINUX TREND

# silverblue is part of a larger movement toward image-based linux
# desktops. peers:
#
#   - FEDORA SILVERBLUE / KINOITE — this section
#   - VANILLA OS                  — debian-based, atomic, container-centric
#   - blendOS                     — arch-based atomic
#   - NixOS                       — declarative + reproducible (different
#                                   model but same goal: deterministic,
#                                   non-drifting system state)
#   - openSUSE Aeon               — opensuse's atomic (formerly MicroOS
#                                   desktop)
#   - PopOS COSMIC                — system76's coming atomic desktop
#   - Fedora CoreOS / IoT         — server / edge variants of the same
#                                   ostree model
#
# the common thesis: TRADITIONAL PACKAGE-BY-PACKAGE OS MANAGEMENT IS
# WRONG FOR DESKTOPS. drift is real. updates should be reversible.
# config should be declarative-ish. the host should be a substrate,
# not a craft project.
#
# silverblue is fedora's bet on this thesis. the family is growing,
# the tooling is maturing, and the uBlue derivatives demonstrate the
# model's flexibility. by 2030, this is likely what "Fedora" means
# for new users (see THE NEXT 5-10 YEARS section).


SHELL AND DEV-ENVIRONMENT PHILOSOPHY
------------------------------------

# fedora workstation (or silverblue) is a great dev machine. but HOW
# to arrange your tools is a recurring question. the answers scattered
# across CONTAINERS, VIRTUAL MACHINES, GHOSTTY, and CLAUDE CODE don't
# add up to a coherent picture. this section is the unified workflow.


# THE PATTERN — FOUR LAYERS

# the fedora-native dev workflow has four conceptual layers:
#
#   PROJECT    — per-project: venv, .tool-versions, devcontainer.json,
#                .envrc
#   TOOLS      — mise / asdf / rustup / nvm / pyenv managing language
#                versions
#   CONTAINER  — toolbox / distrobox (when you need distro-specific
#                tools)
#   HOST       — fedora itself, minimal, stable, unconcerned with
#                project specifics
#
# discipline: push each concern down to the lowest appropriate layer.
# tools that vary by project belong at PROJECT; tools that vary by
# language ecosystem at TOOLS; distro-specific tooling at CONTAINER;
# only genuinely cross-project tools (editor, terminal, git, version
# manager) live on HOST.


# WHY THIS PATTERN — vs the obvious alternatives

# obvious alternative 1: "install everything on the host". works until
# you need python 3.9 for one project and 3.13 for another; until a
# dependency upgrade breaks an old script; until rebuilding from
# scratch takes a day.
#
# obvious alternative 2: "everything in a full VM". works but slow,
# eats RAM, friction discourages experimentation.
#
# layered pattern: keeps the FAST path fast (host) and the ISOLATED
# parts isolated (containers + per-project envs). most everyday work
# is at the project layer (cheap, instant). only distro-specific or
# radically different stacks reach into containers.
#
# bonus: the entire setup is REPRODUCIBLE. onboarding a new machine =
# clone dotfiles + mise install in each project + done. no "i forgot
# what i installed" drift.


# LAYER 1 — HOST: KEEP IT MINIMAL

# only install on the host what you use IRRESPECTIVE of project:
sudo dnf install --needed \
    git neovim tmux ghostty zsh \                  # editor, mux, shell
    ripgrep fd-find bat fzf jq htop \              # cross-project CLI
    podman toolbox distrobox \                     # container tooling
    direnv mise                                    # env switching

# rationale: tools whose VERSION rarely matters across projects. you
# want them current; a major version bump rarely breaks workflows.

# what NOT to install on the host: language runtimes (python, node,
# go, rust). those go through mise. unless you're on silverblue,
# where the choice is forced (see below).


# LAYER 2 — CONTAINER: TOOLBOX / DISTROBOX

# when do you reach for a container?
#
#   - you need a different distro (apt, pacman, etc.) for one task
#   - you're testing software targeting a specific distro version
#   - you're on SILVERBLUE and need to `dnf install` something
#   - you want a sandbox to test unsafe scripts
#   - you're juggling multiple incompatible stacks

# toolbox vs distrobox quick decision:
#   - TOOLBOX   — simpler. fedora-ecosystem-native. /home shared. GUI
#                 apps work but with friction. default for "fedora
#                 version of fedora".
#   - DISTROBOX — more flexible. any image (arch, ubuntu, opensuse).
#                 more init systems. GUI apps clean via distrobox-export.

toolbox create -c f44                              # default: matches host
toolbox enter f44

distrobox create -n ubuntu24 -i docker.io/library/ubuntu:24.04
distrobox enter ubuntu24

# common pattern: one long-lived toolbox/distrobox per language stack
# or per test target (rust-box, go-box, rhel9-test-box). short-lived
# ones for one-off experiments.


# LAYER 3 — TOOLS: MISE (formerly rtx)

# mise is the runtime version manager that's winning the consolidation
# race. one tool managing python, node, go, rust, ruby, java, deno,
# terraform, awscli, kubectl, etc. replaces nvm + pyenv + rustup +
# rbenv + tfenv + ... with one binary + one config format.

# install
sudo dnf install mise                              # repo install
# OR
curl https://mise.run | sh                         # always-current

# add to your shell (zsh shown; bash similar)
echo 'eval "$(mise activate zsh)"' >> ~/.zshrc
exec zsh

# install runtimes
mise install python@3.13
mise install python@3.11 node@22 go@1.23 rust@stable
mise list                                          # what's installed
mise list-all python                               # what versions exist

# project-scoped versions — drop a .tool-versions in your repo:
cd ~/projects/myapp
mise use python@3.13 node@22
cat .tool-versions
#   python 3.13
#   node 22
# cd into the directory → mise auto-switches via the shell hook

# global defaults
mise use -g python@3.13 node@22 go@1.23

# update / install all per-project
mise upgrade
mise install                                       # installs project's
                                                   # .tool-versions


# MISE vs ASDF vs LANGUAGE-SPECIFIC (pyenv / nvm / rustup)

#   - MISE    — modern, fast, all-in-one. polyglot. recommended default.
#               compatible with asdf's .tool-versions format.
#   - ASDF    — earlier polyglot tool. mise was created as a replacement;
#               if asdf works for you, no need to switch.
#   - PYENV   — python-only. solid; mise covers it.
#   - NVM     — node-only. mature; mise covers it.
#   - RUSTUP  — rust-only. the canonical rust toolchain manager; mise
#               wraps it. EXCEPTION: if you need cross-compile targets
#               or fine-grained component control, use rustup directly.
#
# consolidation argument: one config, one tool, per-directory auto-
# switch, direnv integration. one fewer thing to learn per language.


# LAYER 4 — PROJECT: VENVS, devcontainer.json, .envrc

# per-project state lives in the project directory. typical files:
#
#   .tool-versions      — mise / asdf runtime versions
#   .venv/              — python venv (mise creates this automatically)
#   .envrc              — direnv environment overlays
#   devcontainer.json   — microsoft's spec for containerized dev envs
#   .editorconfig       — editor preferences
#   .pre-commit-config  — pre-commit hooks
#   Justfile / Makefile — task automation
#
# none of this lives on the host. clone the repo → mise install →
# direnv allow → start working.

# DIRENV — auto-load .envrc on cd
sudo dnf install direnv
echo 'eval "$(direnv hook zsh)"' >> ~/.zshrc

cat > .envrc <<'EOF'
export DATABASE_URL="postgres://localhost/myapp_dev"
export ANTHROPIC_API_KEY="$(pass api/anthropic)"
layout python
PATH_add bin
EOF
direnv allow                                       # one-time approval

# DEVCONTAINERS — microsoft's spec for "this project's dev env is a
# container". more structured than toolbox/distrobox. supported by
# vscode, jetbrains, neovim (via plugins), and gradually by toolbox.
cat > .devcontainer/devcontainer.json <<'EOF'
{
  "image": "mcr.microsoft.com/devcontainers/python:3.13",
  "postCreateCommand": "pip install -r requirements.txt",
  "customizations": {
    "vscode": { "extensions": ["ms-python.python"] }
  }
}
EOF


# DOTFILES MANAGEMENT

# you want shell / editor / tool configs synced across machines.
# three main approaches:
#
#   - CHEZMOI  — go-based, templates (different content per machine).
#                recommended for modern multi-machine setups. encrypts
#                secrets via age. handles templating cleanly. in repos.
#   - YADM     — git-based, simpler. wraps git with per-host alternates.
#                simpler conceptual model.
#   - GNU STOW — symlink farm. zero magic. the original. fine if your
#                dotfiles are simple and don't need machine variants.

sudo dnf install chezmoi
chezmoi init https://github.com/yourname/dotfiles.git
chezmoi apply

# update on changes
chezmoi edit ~/.zshrc
chezmoi apply


# SECRETS — direnv + age / sops, not env vars in shell config

# stop pasting api keys into ~/.zshrc. patterns that work:
#
#   - DIRENV + .envrc.local       — gitignored per-project secrets
#   - PASS                        — gpg-encrypted password store
#   - AGE                         — modern minimal encryption tool
#   - SOPS                        — mozilla's secrets-in-encrypted-yaml
#   - GNOME KEYRING / 1PASSWORD   — system keyring + CLI integration

# example: direnv + age for project secrets
echo "ANTHROPIC_API_KEY=sk-ant-..." > .env.local
age -r age1... -o .env.local.age .env.local       # encrypt
rm .env.local                                     # delete plaintext

# in .envrc:
#   set +a; eval "$(age -d -i ~/.age-key .env.local.age)"; set -a


# EDITOR + MULTIPLEXER — DELIBERATELY AGNOSTIC

# the layered pattern is editor-AGNOSTIC. works for neovim, vscode,
# jetbrains, helix, zed, emacs. they all read .tool-versions /
# direnv / devcontainer.json correctly.

# the pattern that works regardless of editor:
#   - GHOSTTY or PTYXIS as the terminal
#   - TMUX or ZELLIJ as the multiplexer (one session per project)
#   - editor of choice attached to the multiplexer session
#   - LSP servers installed per-project via mise (not host-wide)


# SILVERBLUE — WHERE THIS PATTERN IS MANDATORY

# on workstation this layered pattern is RECOMMENDED but optional.
# you can still `sudo dnf install python3.13` on the host.
#
# on silverblue (see SILVERBLUE section), this pattern is REQUIRED:
#   - host can't `dnf install` trivially (layering slows upgrades)
#   - the OS assumes exactly this layered model
#   - toolbox/distrobox isn't optional for dev work
#
# silverblue users essentially HAVE to learn this pattern. silver
# lining: once learned, it's the cleanest dev workflow on any linux.
# many users coming from silverblue back to workstation keep the
# pattern because it's simply better.


# HONEST TRADEOFFS

# 1. STARTUP OVERHEAD. entering a toolbox / starting a devcontainer
#    is slower than running on the host. usually <2 seconds; in a
#    fast iteration loop you'll notice.
#
# 2. "WHICH CONTAINER AM I IN" cognitive load. your shell prompt
#    should show this. most defaults handle toolbox; double-check
#    distrobox setup.
#
# 3. DUPLICATED RESOURCES. each toolbox is a full container image —
#    a couple GB. disk gets fragmented if you go overboard.
#    `podman system prune` periodically.
#
# 4. GUI APPS IN CONTAINERS work but with friction. browsers and
#    editors usually live on the HOST and attach to container-side
#    workspaces (via ssh, mount, or LSP-over-stdio).
#
# 5. WAYLAND SOCKET SHARING IS CONFIGURED, NOT MAGIC. toolbox /
#    distrobox set this up; if a GUI app misbehaves, that's where
#    to look first.


# DECISION MATRIX — WHICH LAYER OWNS WHAT

#   "i need git / neovim / ripgrep"                 → HOST
#   "i need a different python per project"         → MISE
#   "i need to test against ubuntu's apt"           → DISTROBOX
#   "i need a database for one project"             → PODMAN (quadlet
#                                                     or in a devcontainer)
#   "vendor tooling i don't want polluting host"    → TOOLBOX
#   "whole project reproducible across machines"    → DEVCONTAINER
#   "i need secrets per project"                    → DIRENV + AGE/SOPS
#   "i'm onboarding a new machine"                  → CHEZMOI + mise install


INOTIFY LIMITS — FILE WATCHER GOTCHA
------------------------------------

# inotify is the kernel mechanism that lets a userspace process get
# notified when files change. VS Code, Node, IntelliJ, Syncthing,
# Dropbox, language servers, and most modern dev tooling rely on it.
# fedora ships with relatively conservative limits — when you hit
# them, the errors look more dramatic than they are.


# SYMPTOMS

# the canonical error messages, all the same underlying cause:
#
#   Node:        Error: ENOSPC: System limit for number of file
#                watchers reached
#   chokidar:    Error: ENOSPC, watch ...
#   VS Code:     "Unable to watch for file changes in this large
#                workspace. Please follow the instructions link..."
#   IntelliJ:    "The current inotify(7) watch limit is too low"
#   Syncthing:   "Failed to set up inotify handler"
#   tail -f:     "Cannot watch ...: No space left on device"
#
# "no space left on device" is misleading — disk is fine. the kernel
# is out of WATCH SLOTS, not blocks.


# INSPECT CURRENT LIMITS

cat /proc/sys/fs/inotify/max_user_watches      # watches per user
cat /proc/sys/fs/inotify/max_user_instances    # inotify fds per user
cat /proc/sys/fs/inotify/max_queued_events     # buffered events / fd

# fedora 44 defaults (subject to kernel version):
#   max_user_watches    ~ 65536 — 524288 (varies by kernel version
#                                          and RAM)
#   max_user_instances  ~ 128
#   max_queued_events   ~ 16384
#
# the first one is what most people exhaust.


# TEMPORARY FIX (until reboot)

sudo sysctl -w fs.inotify.max_user_watches=524288
sudo sysctl -w fs.inotify.max_user_instances=512


# PERSISTENT FIX (across reboots)

sudo tee /etc/sysctl.d/40-max-user-watches.conf <<'EOF'
fs.inotify.max_user_watches = 524288
fs.inotify.max_user_instances = 512
EOF
sudo sysctl --system                            # apply now


# WHY FEDORA'S DEFAULT IS CONSERVATIVE

# each inotify watch consumes ~1 KB of UNSWAPPABLE kernel memory.
# 524288 watches = ~500 MB locked in kernel space. on a 4 GB embedded
# system or a memory-constrained VM, a runaway watcher can starve
# everything else. the conservative defaults are "safe on any
# reasonable hardware".
#
# on a modern desktop (16+ GB RAM), raising to 524288 is fine.
# people pushing 2-4 million watches for very large monorepos can
# do so but should monitor memory.


# FINDING THE OFFENDER

# you've raised limits and still hit them. who's actually using all
# your watches? per-process inotify usage:
for pid in /proc/[0-9]*; do
    n=$(ls $pid/fd 2>/dev/null \
        | while read fd; do
              readlink $pid/fd/$fd 2>/dev/null | grep -q anon_inode:inotify && echo 1
          done | wc -l)
    [ "$n" -gt 0 ] && echo "$n  $(cat $pid/comm 2>/dev/null)  pid=$(basename $pid)"
done | sort -rn | head -20

# alternative (slower but cleaner):
sudo dnf install procps-ng
sudo find /proc/*/fd -lname 'anon_inode:inotify' 2>/dev/null \
    | cut -d/ -f3 | sort | uniq -c | sort -rn | head -20

# typical offenders:
#   - VS Code's file watcher (large monorepos especially)
#   - Node dev servers (vite, webpack, next.js — they watch a lot)
#   - Syncthing (every shared directory)
#   - JetBrains IDEs (intellij, pycharm, goland — each is a process)


# PER-PROCESS CONTAINMENT

# if one app is the only thing eating watches, exclude unwanted paths
# instead of raising limits.
#
# VS CODE — files.watcherExclude in settings.json:
{
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/target/**": true,
    "**/.venv/**": true,
    "**/dist/**": true
  }
}
# this is the right answer for most "VS Code is hitting limits"
# situations — let it watch your source, not node_modules.

# NODE / CHOKIDAR — most file-watching libraries support an `ignored`
# pattern. configure in your dev server's webpack / vite / next config.


# RELATED LIMITS (not inotify but adjacent)

# fs.file-max               — kernel-wide file descriptor cap. rarely
#                             a problem on modern systems.
# ulimit -n / nofile        — per-process fd cap. systemd units can
#                             override via LimitNOFILE=.
# fs.epoll                  — epoll instance limits. relevant for
#                             very-high-connection servers.


# CROSS-REFERENCES

# - SHELL AND DEV-ENVIRONMENT PHILOSOPHY: where the dev-tools stack
#   is described
# - CONTAINERS: containerized dev environments have their own inotify
#   limits (inherited from the host but bounded by per-cgroup limits)


GAMING
------

# linux gaming in 2026 is genuinely good. ~80% of windows games run
# via Proton without configuration. native indie games are plentiful.
# the Steam Deck halo effect drove Valve and game developers to take
# linux seriously. this section is the fedora-native gaming stack.


# PREREQUISITES

# multilib (32-bit libraries — steam, proton, wine all need them):
sudo dnf install glibc.i686

# RPM Fusion enabled (covered in REPOS section). gives you ffmpeg
# (NVENC / VAAPI for streaming), proprietary nvidia driver if needed,
# and binary versions of common gaming-adjacent tools.

# if nvidia: akmod-nvidia from RPM Fusion (covered in NVIDIA section).
# the 545+ driver branch (current default) is fine for gaming on both
# wayland and xorg.


# STEAM — DNF VS FLATPAK

# dnf install — native, deepest integration:
sudo dnf install steam steam-devices
# - steam-devices ships udev rules for controllers (xbox, steam
#   controller, ps4/ps5). install it.
# - native steam picks up host nvidia driver, host libraries, host
#   audio (PipeWire) cleanly.
# - downside: pulls a lot of 32-bit libraries into the system.

# flatpak install — sandboxed, isolated:
flatpak install flathub com.valvesoftware.Steam
# - clean separation from host. all 32-bit libs live inside the
#   flatpak runtime.
# - downside: non-steam-runtime games (the "Add a Non-Steam Game"
#   path) sometimes can't access the host filesystem cleanly. wine
#   bottles outside steam don't see steam's environment.

# RECOMMENDED PICK: native dnf for most users. flatpak if you want
# strict separation, or you're on silverblue (where it's the natural
# path — see SILVERBLUE).


# PROTON — VALVE'S WINDOWS COMPATIBILITY LAYER

# Proton is a downstream Wine fork that Valve maintains. it's the
# magic that makes most windows games "just work" on linux. enabled
# per-game via Steam → Properties → Compatibility → "Force the use
# of a specific Steam Play compatibility tool".

# GE-PROTON — community fork of Proton with extra game fixes. games
# that "almost work" on stock Proton often work on GE-Proton.
# manage versions with ProtonUp-Qt:
flatpak install flathub net.davidotek.pupgui2
# the tool installs GE-Proton into ~/.steam/root/compatibilitytools.d/
# steam picks them up on restart. typical workflow:
#   1. game won't launch on stock Proton
#   2. open ProtonUp-Qt → install latest GE-Proton
#   3. restart steam
#   4. Steam → game → Properties → Compatibility → pick GE-Proton
#   5. try again


# LUTRIS — NON-STEAM WINDOWS GAMES

# steam handles steam games via Proton. for everything else (battle.net,
# GOG, custom wine prefixes, old discs), Lutris is the canonical answer.
# manages wine prefixes per-game with community-maintained install
# scripts.
sudo dnf install lutris
# or:
flatpak install flathub net.lutris.Lutris

# common use: "install battle.net via lutris" pulls the launcher,
# creates a wine prefix, configures D9VK/DXVK, done. similar one-click
# scripts for many older games.


# HEROIC GAMES LAUNCHER — EPIC / GOG / AMAZON NATIVE CLIENT

# the canonical native linux client for Epic Games Store, GOG, and
# Amazon Prime Gaming libraries. plays nicer than wine'd versions of
# the windows launchers.
flatpak install flathub com.heroicgameslauncher.hgl

# you log in with your epic / GOG credentials, download games, and
# heroic configures Proton / Wine wrappers automatically.


# BOTTLES — WINE PREFIX MANAGEMENT WITH MORE FLEXIBILITY

# bottles is a GUI for managing wine "bottles" (isolated prefixes)
# with curated defaults per use case (gaming, application, custom).
# more flexible than Lutris for some workflows but smaller community
# database.
flatpak install flathub com.usebottles.bottles


# GAMEMODE — CPU GOVERNOR + IO TUNING AROUND GAME LAUNCH

# automatically switches to performance governor + tweaks niceness +
# IO scheduler when a game launches. measurable FPS gains on
# laptops. preinstalled on workstation; verify:
rpm -q gamemode
# if missing:
sudo dnf install gamemode

# steam: add `gamemoderun %command%` to launch options. for non-steam:
gamemoderun ./mygame

# verify it's working:
gamemoded -s                                  # status (should be active)


# MANGOHUD — FPS / CPU / GPU OVERLAY

sudo dnf install mangohud
# 32-bit version for 32-bit steam games:
sudo dnf install mangohud.i686

# enable per-game in steam launch options:
#   mangohud %command%
# or globally:
