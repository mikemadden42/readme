    cascadia-code-fonts \
    cascadia-mono-fonts \
    fira-code-fonts \
    google-noto-sans-mono-fonts \
    google-noto-sans-mono-cjk-fonts        # CJK-capable monospace

# enable ligatures (fira code / jetbrains mono / cascadia code):
# in ghostty, ptyxis, vscode, jetbrains — usually a font-feature
# setting in the app's preferences. for terminals on GNOME, ligatures
