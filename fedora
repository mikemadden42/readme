FINGERPRINT READER (LAPTOPS)
----------------------------

# fedora's stack: libfprint (driver library) + fprintd (daemon) +
# authselect (PAM wiring). the biggest gotcha is hardware support —
# many recent laptops ship Goodix or Synaptics readers that need
# specific libfprint versions or third-party drivers. always verify
# support FIRST before installing anything.


# STEP 1 — identify the reader and check support
lsusb | grep -iE 'fingerprint|sensor|biometric'
# cross-reference vendor/product IDs at:
#   https://fprint.freedesktop.org/supported-devices.html


# STEP 2 — install fprintd (usually already on Workstation)
sudo dnf install fprintd fprintd-pam


# STEP 3 — enroll a finger
fprintd-enroll                                # default: right-index
fprintd-enroll -f left-index                  # specific finger
fprintd-list "$USER"                          # verify enrolled fingers
fprintd-delete "$USER" -f left-index          # remove one
# GUI path: Settings → Users → Fingerprint Login (toggle only
# appears when a supported reader is detected).


# STEP 4 — wire into PAM via authselect
# DON'T hand-edit /etc/pam.d/* on fedora — authselect manages PAM
# via profiles, and direct edits get overwritten.
sudo authselect enable-feature with-fingerprint
sudo authselect apply-changes
authselect current                            # verify the feature is on
# this adds fingerprint to sudo, su, login, GDM, and polkit. password
# remains the fallback if the reader fails or you cancel the prompt.


# STEP 5 — test
sudo -k && sudo true                          # should prompt for fingerprint
# then lock the screen (Super+L) and try GDM unlock.


# COMMON GOTCHAS

# 1. lsusb shows the reader but `fprintd-enroll` says "no devices".
#    libfprint doesn't support that exact revision yet. options:
#      - check upstream libfprint issue tracker for your USB ID
#      - try a newer libfprint from COPR if available
#      - for some Synaptics readers, the out-of-tree open-fprintd +
#        python-validity drivers exist (RPM build required; messy)
#
# 2. resume from suspend kills the reader. quick fix:
sudo systemctl restart fprintd
#    if it's persistent, file the kernel bug — there are open ones
#    for several laptop models, sometimes fixed by a firmware update
#    (worth running `fwupdmgr update` first).
#
# 3. Goodix 53xx family is hit-or-miss. some IDs (53b2, 5395, etc.)
#    are in mainline libfprint; others still need vendor patches.
#    check your specific ID against the supported-devices list, not
#    just "Goodix Generic".
#
# 4. fingerprint does NOT unlock LUKS. fingerprint kicks in only
#    post-boot (GDM, sudo, polkit). pre-boot biometric unlock isn't
#    a thing on linux. for hands-off boot, use TPM-backed unlock via
#    systemd-cryptenroll (see [[luks]] / the fedora-to-endeavouros
#    LUKS section) — different mechanism, different threat model.
#
# 5. multiple users: each user enrolls their own fingerprints. there's
#    no system-wide enrollment. enroll while logged in as the user.
#
# 6. disable / uninstall the wiring cleanly:
sudo authselect disable-feature with-fingerprint
sudo authselect apply-changes
fprintd-delete "$USER"                        # remove enrolled prints
sudo dnf remove fprintd-pam                   # optional


POWER MANAGEMENT — SLEEP, HIBERNATE, PROFILES
---------------------------------------------

# the stack on fedora workstation:
#
#   power-profiles-daemon (PPD)  — performance / balanced / power-saver
#                                  modes. fedora's default since F35,
#                                  replaced TLP for most users.
#   GNOME Settings → Power        — UI on top of gsettings keys
#   systemd-logind                — lid switch, power button, idle
#   upower                        — battery state introspection
#   the kernel's cpufreq governor — intel_pstate / amd-pstate driver +
#                                  schedutil governor by default
#
# the four sleep modes (`cat /sys/power/state` shows what's supported):
#
#   suspend (s2idle / S3) — to RAM, quick resume, small power draw
#   hibernate             — to disk, zero power, slow resume
#   suspend-then-hibernate — to RAM first, then to disk after a delay
#   hybrid-sleep          — to RAM + disk simultaneously


# AUTOMATIC SUSPEND TIMEOUTS

# Settings → Power → "Automatic Suspend" (it's a click-through, not an
# inline toggle — opens a dialog with separate "On Battery" and
# "Plugged In" toggles).
#
# desktops or docked-only laptops: no battery = GNOME hides the
# battery/AC distinction. you get a single "Suspend when inactive"
# toggle, or nothing.

# CLI equivalents under org.gnome.settings-daemon.plugins.power:
gsettings list-recursively org.gnome.settings-daemon.plugins.power \
    | grep -E 'sleep|idle'

# AC behavior (plugged in):
gsettings set org.gnome.settings-daemon.plugins.power \
    sleep-inactive-ac-type 'suspend'        # or 'nothing' / 'hibernate'
gsettings set org.gnome.settings-daemon.plugins.power \
    sleep-inactive-ac-timeout 1800          # 30 min

# battery behavior:
gsettings set org.gnome.settings-daemon.plugins.power \
    sleep-inactive-battery-type 'suspend'
gsettings set org.gnome.settings-daemon.plugins.power \
    sleep-inactive-battery-timeout 900      # 15 min

# screen blank — separate setting; screen off but system stays awake:
gsettings set org.gnome.desktop.session idle-delay 600

# workstation defaults: screen blanks at 5 min, battery suspends at 15
# min, AC suspends at 20 min. it's never literally "always on" by
# default, but people often miss the AC case because the timeout is
# generous.


# POWER PROFILES

# performance / balanced / power-saver via power-profiles-daemon.
# CLI:
powerprofilesctl list
powerprofilesctl get
powerprofilesctl set performance              # max perf, hot, loud fans
powerprofilesctl set balanced                 # default
powerprofilesctl set power-saver              # tighten timeouts, cap CPU
powerprofilesctl version

# GUI: Settings → Power → Power Mode, OR click the system-tray battery
# icon — the three options appear there.
#
# the kernel responsively biases the cpufreq governor and may
# tweak boost / thermal headroom based on the chosen profile.


# LID SWITCH AND POWER BUTTON — logind, not GNOME

# /etc/systemd/logind.conf controls these, NOT the GNOME panel:
#
#   HandleLidSwitch=                  what closing the lid does
#   HandleLidSwitchExternalPower=     same, but only when plugged in
#   HandleLidSwitchDocked=            same, but only when docked
#   HandlePowerKey=                   short power-button press
#   HandlePowerKeyLongPress=          held power-button press
#   HandleSuspendKey=                 hardware suspend key
#   HandleHibernateKey=               hardware hibernate key
#
# valid actions: ignore, poweroff, reboot, halt, kexec, suspend,
# hibernate, hybrid-sleep, suspend-then-hibernate, lock.

# common scenario: laptop hooked to an external monitor, don't want
# lid-close to suspend:
sudo mkdir -p /etc/systemd/logind.conf.d
sudo tee /etc/systemd/logind.conf.d/lid.conf <<'EOF'
[Login]
HandleLidSwitch=suspend
HandleLidSwitchExternalPower=ignore
HandleLidSwitchDocked=ignore
EOF
sudo systemctl restart systemd-logind
# warning: this kicks you out of your gnome session. save first.


# HIBERNATE — SETUP IS NOT AUTOMATIC

# hibernate writes the entire RAM state to swap, then powers off
# fully. it requires:
#   - swap space >= total RAM size (ideally with ~20% headroom)
#   - a `resume=` kernel parameter pointing at the swap location
#   - the kernel built with hibernation support (fedora's is)
#   - secure boot may need extra config (signed hibernation image)

# check if hibernation is currently available:
cat /sys/power/state                          # should list 'disk'
cat /sys/power/disk                           # methods available
systemctl status hibernate.target

# if you picked "Swap (with Hibernate)" in calamares / anaconda at
# install time, this is already set up:
swapon --show                                 # confirm swap >= RAM
cat /proc/cmdline | grep -o 'resume=[^ ]*'    # confirm resume= present

# if NOT — easiest fix is creating a swapfile (btrfs needs care):
sudo touch /swapfile
sudo chattr +C /swapfile                      # btrfs: nodatacow REQUIRED
sudo fallocate -l 32G /swapfile                # match your RAM
sudo chmod 600 /swapfile
sudo mkswap /swapfile
sudo swapon /swapfile
echo '/swapfile none swap defaults 0 0' | sudo tee -a /etc/fstab
# add resume= kernel arg pointing at swap device + offset:
sudo grubby --update-kernel=ALL \
    --args="resume=UUID=$(findmnt / -no UUID) resume_offset=$(sudo filefrag -v /swapfile | awk 'NR==4 {print $4}' | tr -d '.')"

# test:
systemctl hibernate
# after resume, verify: `last -x | head` should show no clean shutdown
# between hibernation and now.


# SUSPEND-THEN-HIBERNATE — the hybrid people actually want

# suspends to RAM first (quick resume), then hibernates after a
# configurable delay (saves battery overnight). configure in
# /etc/systemd/sleep.conf:
sudo tee /etc/systemd/sleep.conf.d/hybrid.conf <<'EOF'
[Sleep]
HibernateDelaySec=2h
EOF
# trigger:
systemctl suspend-then-hibernate
# bind it to lid-close (laptops):
#   set HandleLidSwitch=suspend-then-hibernate in logind.conf
# bind it to the gnome auto-suspend action:
#   gsettings set org.gnome.settings-daemon.plugins.power \
#       sleep-inactive-battery-type 'suspend-then-hibernate'


# TLP vs POWER-PROFILES-DAEMON — DON'T RUN BOTH

# historical advice ("install TLP for laptop battery") is outdated for
# fedora. power-profiles-daemon is the default and is what GNOME's
# power-mode selector controls. TLP is a separate tool with much
# finer-grained tuning knobs (per-device USB autosuspend, PCIe ASPM,
# wifi power-save, disk APM, etc.).
#
# they CONFLICT. running both produces unpredictable behavior. if you
# install TLP, you must mask PPD:
sudo dnf install tlp tlp-rdw
sudo systemctl mask power-profiles-daemon
sudo systemctl enable --now tlp
# config: /etc/tlp.conf

# the question of which to use: PPD is enough for 90% of users. TLP
# is worth it ONLY if you've measured a real problem PPD can't fix
# (specific USB device draining battery at idle, wifi card not
# entering low-power state, etc.). default to PPD.


# BATTERY MONITORING

# list power devices:
upower -e

# detailed battery state (substitute the BAT path from -e):
upower -i $(upower -e | grep -m1 BAT)
# look for: energy-full / energy-full-design (capacity vs new)
#           capacity (% of design — battery health, <80% means worn)
#           time-to-empty (current rate of discharge)

# gnome-power-statistics shows it graphically:
sudo dnf install gnome-power-manager
gnome-power-statistics


# POWERTOP — IDENTIFY POWER HOGS

sudo dnf install powertop
sudo powertop                                  # interactive UI
sudo powertop --html=/tmp/power-report.html    # report

# `sudo powertop --auto-tune` applies every suggested tweak in one
# shot. famously aggressive — can break wifi, USB devices, brightness
# keys. don't run it blindly. read the suggestions, apply the safe
# ones in /etc/tmpfiles.d/.


# COMMON GOTCHAS

# 1. SUSPEND WAKES UP IMMEDIATELY. usually a USB device generating wake
#    events (mouse jitter, keyboard, hub). find culprits:
cat /proc/acpi/wakeup
#    disable wake from a device (substitute the device id):
echo XHC | sudo tee /proc/acpi/wakeup

# 2. WIFI / BLUETOOTH BROKEN AFTER SUSPEND. firmware quirk on some
#    chipsets. quick fix:
sudo systemctl restart NetworkManager
#    persistent: kernel cmdline workaround `iwlwifi.power_save=0`
#    or similar (varies by chipset).

# 3. NVIDIA + SUSPEND. covered in the NVIDIA section above —
#    enable the nvidia-suspend / -resume / -hibernate systemd units.

# 4. HIBERNATE FAILS SILENTLY. usually swap is too small, OR resume=
#    kernel parameter is missing or wrong:
journalctl -b -1 -g hibernate                  # check the failed boot
journalctl -b 0 -g resume

# 5. SECURE BOOT + HIBERNATE. some firmwares refuse to resume a
#    hibernation image under secure boot (treats it as code-signing
#    violation). either disable secure boot or use a signed
#    kernel + signed hibernation setup (rare on fedora workstation).

# 6. BATTERY % JUMPS OR STICKS AT 0% / 100%. calibration drift in
#    the embedded controller. discharge to empty + charge to full a
#    few cycles, or check vendor's firmware via fwupd for a calibration
#    update.

# 7. DISABLE SLEEP ENTIRELY (servers, kiosks). mask the targets:
sudo systemctl mask sleep.target suspend.target hibernate.target \
    hybrid-sleep.target

# 8. DESKTOPS SOMETIMES SUSPEND ON SCREEN BLANK. usually because GNOME
#    detected a fake "battery" device (UPS plugged in to USB) and is
#    applying laptop defaults. either remove the udev quirk or set
#    sleep-inactive-ac-type='nothing'.


# WHAT TO CHECK FIRST WHEN POWER MISBEHAVES

powerprofilesctl get                           # current profile
gsettings list-recursively org.gnome.settings-daemon.plugins.power \
    | grep -E 'sleep|idle'
cat /etc/systemd/logind.conf                   # lid / power button
journalctl -b -g -E 'suspend|hibernate|resume' # recent transitions
upower -i $(upower -e | grep -m1 BAT)          # battery state


AUDIO — PIPEWIRE
----------------

# pipewire replaced pulseaudio as fedora's default audio server in
# F34 (2021) — one of fedora's flagship contributions to modern linux.
# the pitch: one daemon doing the job that three separate stacks
# (PulseAudio for desktop, JACK for pro audio, ALSA for low-level) used
# to share badly.


# THE STACK

#   PipeWire        — the core multimedia server. handles audio AND
#                     video routing (screen capture for wayland flows
#                     through here too).
#   WirePlumber     — the session manager. policy, device routing,
#                     "auto-switch to bluetooth when it connects".
#                     swappable but the default everyone uses.
#   pipewire-pulse  — compatibility shim. old `pactl`, `pavucontrol`,
#                     and the PulseAudio API keep working transparently.
#   pipewire-jack   — JACK compatibility. `pw-jack <app>` launches a
#                     JACK client without a separate JACK daemon.
#   pipewire-alsa   — ALSA compatibility. apps using the ALSA API still
#                     work; their output flows into PipeWire's graph.
#
# all of the above are preinstalled on workstation. nothing to set up
# unless you're customizing.


# WPCTL — DAILY COMMANDS

# `wpctl` is the modern CLI (ships with wireplumber). much cleaner than
# the old `pactl`.

wpctl status                                   # devices + default + clients
wpctl get-volume @DEFAULT_AUDIO_SINK@         # current volume
wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.6      # 60%
wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+      # +5%
wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
wpctl set-default <id>                         # change default sink

# typical wpctl status output lists devices with numeric IDs in []
# brackets. use those IDs with set-default and other commands.


# PACTL / PAVUCONTROL — THE COMPATIBILITY PATH

# old PulseAudio commands still work via pipewire-pulse. useful when
# documentation or scripts assume PulseAudio:
pactl list short sinks                         # the classic
pactl set-sink-volume @DEFAULT_SINK@ 60%

# pavucontrol — the GTK GUI mixer with per-app controls. essential for
# "this app is going to the wrong output":
sudo dnf install pavucontrol
pavucontrol


# PW-CLI AND PW-LINK — GRAPH INSPECTION

# pipewire models audio as a NODE GRAPH (like JACK). nodes are sinks,
# sources, apps, hardware. links connect them. inspect:
pw-cli list-objects | grep -i node             # all nodes
pw-cli info <id>                               # details for one
pw-link --output --input                       # show every connection
pw-link --linkable                             # what could be connected

# manually link two nodes (e.g. route firefox to bluetooth headphones):
pw-link "firefox:output_FL" "bluez_output.XX:playback_FL"
pw-link -d "firefox:output_FL" "bluez_output.XX:playback_FL"  # disconnect

# the graphical option for the same: qpwgraph or helvum.
sudo dnf install qpwgraph                      # qt-based
sudo dnf install helvum                        # gtk-based


# GNOME SOUND PANEL — WHAT'S THERE

# Settings → Sound. covers:
#   - default output / input + volume
#   - per-app volume (Applications section)
#   - alerts sound
#   - test speakers (left/right channel checker)
#
# what's NOT there: per-stream routing (use pavucontrol), bluetooth
# codec selection (no GUI; CLI or WirePlumber config), JACK setup.


# BLUETOOTH AUDIO — CODEC SELECTION

# bluetooth audio quality depends on the CODEC negotiated between
# device and host. ranked roughly best → worst:
#
#   LDAC          — sony's high-bitrate codec (~990 kbps). best for
#                   sony headphones; supported on linux.
#   aptX HD       — qualcomm's hi-res codec (576 kbps). many high-end
#                   non-sony headphones.
#   aptX          — qualcomm's standard codec (~352 kbps).
#   AAC           — apple's standard codec (~256 kbps).
#   SBC XQ        — high-bitrate SBC; widely compatible.
#   SBC           — the lowest-common-denominator codec. what you get
#                   if nothing else is negotiated.

# pipewire negotiates the best mutually-supported codec automatically.
# verify what you got:
pw-dump | grep -A2 'codec'                    # look for codec name
wpctl status                                   # bluetooth sink line

# force a specific codec for a device — edit wireplumber config:
sudo mkdir -p /etc/wireplumber/wireplumber.conf.d
sudo tee /etc/wireplumber/wireplumber.conf.d/51-bluez-codecs.conf <<'EOF'
monitor.bluez.properties = {
  bluez5.enable-sbc-xq        = true
  bluez5.enable-msbc          = true
  bluez5.enable-hw-volume     = true
  bluez5.codecs               = [ ldac aptx_hd aptx aac sbc_xq sbc ]
}
EOF
systemctl --user restart wireplumber pipewire pipewire-pulse

# common: "my $400 headphones sound terrible." 90% of the time the
# codec is SBC because bluez or wireplumber didn't enable the higher
# codecs. the above config fixes it.


# MICROPHONE CONFIGURATION

# default input
wpctl set-default <id>                         # find ID via wpctl status
wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 80%

# test:
arecord -d 5 test.wav && aplay test.wav        # 5-second mic test


# EASYEFFECTS — NOISE SUPPRESSION + EQ + PRESETS

# the GTK app for real-time audio processing. modern replacement for
# PulseEffects. install + run:
flatpak install flathub com.github.wwmm.easyeffects
flatpak run com.github.wwmm.easyeffects

# what it gives you:
#   - input chain (microphone): noise suppression (RNNoise), gate,
#     compressor, EQ. the "i sound professional on zoom" toolkit.
#   - output chain (speakers/headphones): equalizer, loudness, bass
#     enhancement, room correction
#   - presets community: github.com/wwmm/easyeffects/wiki/Community-Presets
#
# the noise-suppression preset alone is worth the install — RNNoise
# is genuinely impressive on noisy environments.


# JACK COMPATIBILITY — MUSIC PRODUCTION

# old workflow: stop pulseaudio, start jackd, route apps. terrible.
# pipewire workflow: launch any JACK app via pw-jack, get JACK semantics
# (low latency, exact routing) without any daemon switching.
sudo dnf install pipewire-jack-audio-connection-kit
pw-jack ardour                                 # launch ardour as a JACK client
pw-jack qpwgraph                               # visual routing

# professional audio production: ardour, reaper (native linux), bitwig,
# carla. all work via pw-jack out of the box.


# LOW-LATENCY TUNING

# pipewire uses QUANTUM (buffer size in samples) and RATE (sample
# rate Hz). lower quantum = lower latency = more CPU.
#
# inspect / change at runtime:
pw-metadata -n settings 0 clock.force-quantum 256       # 256 samples
pw-metadata -n settings 0 clock.force-rate 48000        # 48 kHz
pw-metadata -n settings 0 clock.force-quantum 0         # back to auto

# persistent config — drop in /etc/pipewire/pipewire.conf.d/:
sudo tee /etc/pipewire/pipewire.conf.d/99-lowlatency.conf <<'EOF'
context.properties = {
  default.clock.rate          = 48000
  default.clock.quantum       = 512
  default.clock.min-quantum   = 256
  default.clock.max-quantum   = 1024
}
EOF
systemctl --user restart pipewire pipewire-pulse

# typical latencies:
#   quantum 1024 / 48k = ~21ms — desktop, browsers, video
#   quantum 512 / 48k  = ~10ms — gaming, general production
#   quantum 256 / 48k  = ~5ms  — live performance, vocals
#   quantum 64 / 48k   = ~1ms  — pro audio (needs RT kernel realistically)


# COMMON GOTCHAS

# 1. AUDIO GONE AFTER SUSPEND. usually wireplumber lost the device.
#    fix:
systemctl --user restart wireplumber pipewire pipewire-pulse
#    if persistent, check `journalctl --user -u pipewire -b -1` for
#    the suspend / resume transition.
#
# 2. PER-APP VOLUME STICKS AT WRONG VALUE. state lives in
#    ~/.local/state/wireplumber/. delete the relevant restore file
#    and reset:
rm -rf ~/.local/state/wireplumber/
systemctl --user restart wireplumber
#
# 3. HDMI AUDIO MISSING. HDMI sink only appears when a display is
#    attached at pipewire start. plug HDMI, then:
systemctl --user restart wireplumber
#
# 4. BLUETOOTH HEADPHONES KEEP DISCONNECTING. usually BlueZ +
#    PipeWire ordering issue or power-save on the bluetooth radio.
#    workaround:
sudo tee /etc/modprobe.d/bluetooth-powersave.conf <<'EOF'
options btusb enable_autosuspend=0
EOF
sudo dracut --force
#
# 5. THE WRONG SINK BECAME DEFAULT after plugging in USB headphones.
#    wireplumber should auto-switch but doesn't always. force:
wpctl set-default <new-id>
#    persistent: WirePlumber's "default-policy" config controls auto-
#    switch behavior. in /etc/wireplumber/main.lua.d/.
#
# 6. PIPEWIRE VS ALSA LOOPBACK for recording system audio. the modern
#    way is pavucontrol → Recording tab → pick "Monitor of <output>"
#    for an app like OBS. or pw-link the output's monitor port to
#    OBS's input.
#
# 7. APPS USING "snd_aloop" KERNEL MODULE WON'T SEE PIPEWIRE STREAMS.
#    they're talking to raw ALSA. either redirect via pw-link or
#    configure the app to use the pulseaudio API.


# DECISION MATRIX — WHICH TOOL FOR WHAT

#   "set my volume / mute / default"           → wpctl
#   "GUI mixer with per-app control"           → pavucontrol
#   "visualize the audio graph"                → qpwgraph / helvum
#   "noise-cancel my mic for calls"            → EasyEffects
#   "low-latency for music production"         → pw-jack + tuned quantum
#   "force a bluetooth codec"                  → wireplumber config
#   "route firefox to bluetooth manually"      → pw-link
#   "old pulseaudio script needs to work"      → pactl (still works)


BLUETOOTH — BLUEZ, PAIRING, AND PAIN POINTS
-------------------------------------------

# the bluetooth stack as a whole. AUDIO covers the codec /
# wireplumber side; this section covers everything else —
# pairing, HID devices, file transfer, LE, and the recipes for
# when something inevitably misbehaves.
#
# honest preamble: bluetooth on linux in 2026 is much better
# than 2018, but it's still the most frequent source of
# daily-driver friction. budget patience.


# THE STACK (KNOW WHO'S DOING WHAT)

# bluetooth on fedora is a layer cake. when something breaks,
# matching the symptom to the layer is most of the diagnosis.
#
#   1. radio        — the chip (intel cnvi, broadcom, mediatek,
#                     realtek). rfkill can soft-block it.
#   2. kernel       — btusb (USB chips) / hci_uart (UART) drivers.
#                     dmesg messages live here. firmware too.
#   3. bluetoothd   — the BlueZ daemon (systemd unit `bluetooth`).
#                     handles pairing, the dbus API, device DB
#                     in /var/lib/bluetooth/<adapter>/<device>/.
#   4. consumer     — depends on the device:
#                       audio          → pipewire + wireplumber
#                       keyboard/mouse → kernel HID (uhid)
#                       file transfer  → obexd
#                       LE / GATT      → dbus / bluez API
#
# when a device "doesn't work", first ask: did pairing complete
# at layer 3, but the consumer at layer 4 didn't pick it up? or
# did the radio at layer 1 even come up?

# fast health check:
rfkill list                                   # soft/hard block status
systemctl status bluetooth                    # daemon up?
bluetoothctl show                             # adapter info, powered, discoverable
dmesg | grep -iE 'bluetooth|hci|btusb' | tail -50


# PAIRING — THE 95% PATH AND THE CLI

# GNOME Settings → Bluetooth is the supported flow. it covers
# most devices, including the "next to my laptop" pairing for
# AirPods, gaming controllers, mice, and headphones.

# when GNOME is being uncooperative (the device shows up and
# vanishes, or won't pair past discovery), drop to the CLI.
# bluetoothctl is the swiss-army knife:

bluetoothctl                                   # interactive shell
# inside the shell:
power on
agent on
default-agent
scan on                                        # devices appear over ~30s
devices                                        # list discovered
pair AA:BB:CC:DD:EE:FF
trust AA:BB:CC:DD:EE:FF                        # auto-reconnect later
connect AA:BB:CC:DD:EE:FF
info AA:BB:CC:DD:EE:FF                         # capabilities, services, paired?
quit

# one-liners (work outside the interactive shell too):
bluetoothctl devices Paired
bluetoothctl info AA:BB:CC:DD:EE:FF
bluetoothctl disconnect AA:BB:CC:DD:EE:FF
bluetoothctl remove AA:BB:CC:DD:EE:FF          # forget completely

# the GUI fallback when GNOME is misbehaving:
sudo dnf install blueman
blueman-manager
# blueman is a GTK app from the broader linux ecosystem. exposes
# more knobs (PAN tethering, audio profile switching, manual
# service connect) than gnome's stripped-down panel.


# KEYBOARDS, MICE, GAMING CONTROLLERS

# bluetooth HID devices hand off to the kernel's uhid driver
# after pairing — no userspace plumbing required.
#
# pairing quirks:
#   - keyboards often display a PIN on screen; type it on the
#     keyboard and press Enter. some Logitech / Apple keyboards
#     pair without a PIN at all.
#   - gaming controllers (Xbox, DualSense, Switch Pro) typically
#     auto-connect after pairing. for Steam, also enable
#     "Steam Input" in BPM → Controller Settings.
#   - some Apple Magic devices need apple-magic-mouse2 / hid-apple
#     kernel module options for clicks-vs-taps and scroll
#     direction.

# multi-host devices (Logitech MX Keys / MX Master with 3 paired
# hosts) work fine — just pair on each host and use the device's
# host-switch button.


# AUDIO — KEEP IT BRIEF, CROSS-REF AUDIO

# the codec story (LDAC / aptX HD / AAC / SBC), the bidirectional
# mic tradeoff (A2DP-only vs HSP/HFP), and the wireplumber config
# to force a specific codec all live in the AUDIO section's
# "BLUETOOTH AUDIO — CODEC SELECTION" subsection.
#
# the short version: pipewire negotiates the best mutually-
# supported codec automatically. if you got SBC and expected
# LDAC, see AUDIO for the config snippet that whitelists codecs.

wpctl status                                   # current sink + codec
pactl list cards | grep -A20 bluez            # available profiles


# FILE TRANSFER (OBEX) — STILL A THING

# pushing a file from your phone to the laptop or vice-versa.
# fedora ships gnome-bluetooth + obexd; the GNOME Settings
# panel exposes "Send files via Bluetooth" when a device is
# connected.

# cli alternatives (when GNOME's path is broken):
sudo dnf install obex-data-server bluez-tools
obexctl                                        # bluez-tools, interactive
# or one-shot push:
bt-obex --push -d AA:BB:CC:DD:EE:FF ~/myfile.pdf

# the deprecated `bluetooth-sendto` from older fedora still
# works on F44 but is being phased out. prefer obexctl going
# forward.


# BLUETOOTH LE / GATT (FOR SMART-DEVICE TINKERING)

# Bluetooth LE devices (smart bulbs, fitness trackers, BLE beacons,
# Mi Flora plant sensors) speak GATT, not classic profiles. the
# old `gatttool` is deprecated; bluetoothctl now handles GATT:

bluetoothctl
connect AA:BB:CC:DD:EE:FF
menu gatt
list-attributes
select-attribute /org/bluez/.../service00xx/char00yy
attribute-info
read
write "0x01 0x02"
back

# scripting LE: use python-bleak (pip / dnf install python3-bleak)
# or rust's btleplug crate. the dbus API works directly but the
# wrappers are dramatically easier.


# WON'T RECONNECT AFTER SUSPEND — THE CLASSIC

# the symptom: laptop wakes, the headset / mouse doesn't come
# back. usually the radio is fine but the USB controller behind
# it got autosuspended.

# the cheap reset that fixes most of these:
sudo systemctl restart bluetooth

# the more durable fix — disable USB autosuspend on the bluetooth
# device. find the right device first:
for f in /sys/bus/usb/devices/*/product; do
    [ -f "$f" ] && grep -l -i 'bluetooth' "$f"
done
# then for that device, e.g. /sys/bus/usb/devices/1-7:
echo on | sudo tee /sys/bus/usb/devices/1-7/power/control
# persist with a udev rule (see /etc/udev/rules.d/) or with
# the kernel cmdline:
#   btusb.enable_autosuspend=0

# pairs with POWER MANAGEMENT — the laptop's overall suspend
# behavior affects what bluetooth has to recover from.


# DUAL-BOOT PAIRING TRICK (THE CLASSIC GOTCHA)

# pairing a single device (mouse, keyboard, headphones) on BOTH
# windows and fedora means each OS stores a different link key
# under the SAME device MAC. result: the device re-pairs
# successfully on the OS you just booted, breaking the OTHER OS.
# you re-pair forever.

# fix: copy the link key from windows into linux so both sides
# share the same secret. only needed on classic BT, not BLE.
#
# 1. boot windows, pair the device
# 2. reboot to a windows recovery tool (Linux NTFS read works
#    too if you can mount the windows registry hive)
# 3. read the LTK / IRK from:
#    HKLM\SYSTEM\CurrentControlSet\Services\BTHPORT\Parameters\Keys
# 4. write it into linux's device file:
#    /var/lib/bluetooth/<adapter-MAC>/<device-MAC>/info
#    in the [LinkKey] / [LongTermKey] section
#
# tools that automate this: bt-dualboot, bluetooth-dualboot-bug
# (community scripts on github). worth searching when you hit it.


# FIRMWARE QUIRKS

# the kernel ships most bluetooth firmware via the `linux-firmware`
# package. when a NEW chip is reported "broken on linux", the
# fix is almost always a firmware/driver update — both arrive
# with the next kernel.

# intel cnvi / wifi+bt combo chips occasionally need iwlbtu /
# iwlwifi blob updates:
rpm -q linux-firmware                          # version
dnf list updates linux-firmware                # newer available?
sudo dmesg | grep -iE 'firmware|btusb'         # what loaded, what failed

# realtek 8761/8852 chips have historically needed quirky firmware;
# fedora packs these in `linux-firmware`. if dmesg complains about
# missing rtl_bt/<file>.bin, file a bug.


# TROUBLESHOOTING RECIPES

# 1. device not found at all after a kernel update
rfkill list
sudo rfkill unblock bluetooth                  # in case soft-blocked
systemctl status bluetooth
sudo systemctl restart bluetooth
dmesg | grep -iE 'bluetooth|btusb' | tail -40
# if it's a USB-attached BT dongle, try a different port.

# 2. intermittent disconnects on otherwise-paired devices
#    BlueZ's experimental features fix several real disconnect
#    bugs. enabled by default in newer fedora, but worth checking:
grep -i Experimental /etc/bluetooth/main.conf
# if absent, add under [General]:
#   Experimental = true
sudo systemctl restart bluetooth

# 3. device pairs but never appears as a usable input/audio
#    check whether the kernel HID / pipewire took over:
bluetoothctl info AA:BB:CC:DD:EE:FF | grep -i 'connected\|UUIDs'
# for audio: pactl list cards | grep -A20 bluez
# for HID:   ls /sys/class/input/
sudo journalctl -u bluetooth -n 100

# 4. "pairing successful" then immediate disconnect
sudo journalctl -u bluetooth -f &              # watch in another shell
# retry pairing. common causes:
#   - LE secure connections mismatch (old device firmware)
#   - userspace agent missing (you forgot `agent on; default-agent`
#     in bluetoothctl)
#   - device's PIN code requirement; use bluetoothctl, not
#     gnome's silent pair


# HONEST TRADEOFFS

# linux bluetooth has improved dramatically with bluez 5.x and
# pipewire, but it's still:
#   - the most common laptop suspend regression
#   - the most likely to need firmware updates per kernel
#   - the most opaque to debug when GNOME's UI swallows errors
#
# strategies that compound:
#   - keep linux-firmware current (it auto-updates with dnf)
#   - prefer well-supported headphones (sony, bose, anker) over
#     niche brands with proprietary apps
#   - for critical "calls must work" rigs, USB headset > BT
#   - keep blueman in your back pocket as the diagnostic GUI


# QUICK REFERENCE

#   pair the easy way                → GNOME Settings → Bluetooth
#   pair from the cli                → bluetoothctl: scan / pair / trust / connect
#   force a specific audio codec     → see AUDIO → BLUETOOTH AUDIO
#   "device disappeared post-resume" → systemctl restart bluetooth
#   "audio sounds awful"             → AUDIO codec config + check HSP/HFP profile
#   "dual-boot keeps re-pairing"     → copy LTK from windows registry
#   "what does dmesg say?"           → dmesg | grep -iE 'bluetooth|btusb|hci'
#   "GNOME is being weird"           → blueman-manager
#   "BLE smart-device tinkering"     → bluetoothctl gatt menu / python-bleak
#   "intermittent disconnects"       → Experimental = true in main.conf


