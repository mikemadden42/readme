cat > ~/.config/MangoHud/MangoHud.conf <<'EOF'
gpu_stats
cpu_stats
fps
frame_timing
ram
vram
gpu_temp
cpu_temp
position=top-left
font_size=20
toggle_hud=F12
EOF


# VKBASALT — POST-PROCESSING SHADERS

# vulkan layer for FXAA, CAS (AMD's contrast-adaptive sharpening),
