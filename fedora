# JAPANESE:
sudo dnf install mozc                          # ibus-mozc (default)
sudo dnf install fcitx5-mozc                   # for fcitx5 users
# mozc is google's open-source japanese IME (anthy is the older
# alternative).

# CHINESE:
sudo dnf install ibus-libpinyin                # pinyin (mainland)
sudo dnf install ibus-rime                     # rime engine
                                                # (cantonese, etc.)
