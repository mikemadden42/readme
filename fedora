sudo dnf install fcitx5-hangul


# EMOJI INPUT

# GNOME has a built-in emoji picker — Ctrl+. or Ctrl+; in any text
# field. works system-wide on wayland. no install needed.

# more sophisticated typing assistance:
sudo dnf install ibus-typing-booster
