# on non-GNOME wayland (sway, hyprland):
sudo dnf install gammastep
# gammastep <location-options>; configure via
# ~/.config/gammastep/config.ini


# HDR — STILL EXPERIMENTAL, GETTING REAL

# fedora 44 ships kernel + mutter with KMS HDR plumbing
# (HDR10 metadata, BT.2020, PQ EOTF). it works for some uses,
# doesn't for others.

# enable:
gsettings set org.gnome.mutter experimental-features \
    "['scale-monitor-framebuffer','xwayland-native-scaling','hdr']"

# what works on F44:
#   - games via gamescope (steam → properties → launch options:
#     `gamescope -W 2560 -H 1440 -r 165 --hdr-enabled -- %command%`)
#   - mpv with vo=gpu-next and target-prim=auto
#   - obs studio HDR capture (with proper preset)
#
# what's flaky:
#   - browser video (chromium/firefox HDR is still landing)
#   - non-gamescope native games
#   - SDR content on HDR mode (tone-mapping varies by output)
#
# this section will date faster than anything else here. the
# fedora wiki and reddit r/linux_gaming track it best.


# VRR — FREESYNC / G-SYNC ON LINUX

# variable refresh rate is supported at the KMS level for
# AMD (FreeSync) and recent NVIDIA (G-Sync compatible).

# enable in mutter (F44+):
gsettings set org.gnome.mutter experimental-features \
    "['variable-refresh-rate','scale-monitor-framebuffer']"

# verify the panel and cable both support it:
xrandr --props | grep -i 'vrr\|variable'             # on Xorg session
# (no clean wayland equivalent; mutter logs "VRR enabled for
# output X" in journalctl -u gdm if you have debug enabled)

# the per-game story — gamescope can negotiate VRR for games
# that don't speak it natively. tearing in some apps is still
# possible; toggle on/off if you see weirdness in non-game UIs.


# REFRESH-RATE MATCHING FOR VIDEO

# mutter can briefly switch refresh rate while a video is
# fullscreen so 24fps content plays without judder on a 60Hz
# panel. opt-in:
gsettings set org.gnome.mutter experimental-features \
    "['rt-scheduler','dma-buf-screen-sharing']"
# (the specific 'refresh-rate-matching' flag landed and was
# folded into default behavior in gnome 46+; check the schema
# on your installed version.)

# mpv has its own player-side matching that works well:
echo 'video-sync=display-resample' >> ~/.config/mpv/mpv.conf
echo 'interpolation=yes'           >> ~/.config/mpv/mpv.conf


# TOOLS — DISPLAY MANAGEMENT FROM THE CLI

# under GNOME's wayland session, randr-style CLIs are limited
# because mutter owns layout. you have:

# gnome-randr-rs (rust, gnome-specific wayland):
sudo dnf install gnome-randr        # may need a copr; check
gnome-randr                         # list outputs
gnome-randr --output DP-1 --mode 3840x2160@144

# wlr-randr (works on wlroots compositors — sway, hyprland.
# NOT gnome):
sudo dnf install wlr-randr
wlr-randr

# kanshi (auto-config laptop+dock arrangements based on
# connected outputs — wlroots compositors):
sudo dnf install kanshi
# ~/.config/kanshi/config defines profiles per output set;
# kanshi swaps automatically when you dock/undock.

# X11 only — still useful in an Xorg session:
xrandr --output DP-1 --mode 2560x1440 --rate 144 --primary
xrandr --output HDMI-1 --rotate left


# X11 FALLBACK — WHEN AND HOW

# fedora's GDM defaults to a wayland session. for X11 use cases
