# FONTCONFIG — THE FONT MATCHING SYSTEM

# fontconfig decides which font renders each character. when an app
# says "render this in DejaVu Sans" but the character isn't in
# DejaVu, fontconfig picks a fallback. this matters most for CJK
# users: without correct fallback ordering, characters render as the
# dreaded box.

# what fonts are installed:
fc-list                                        # everything
fc-list :lang=ja                               # japanese-capable
fc-list :lang=zh-cn                            # simplified chinese
fc-list :lang=zh-tw                            # traditional chinese
fc-list :lang=ko                               # korean

# which font would render specific characters:
fc-match 'sans-serif'                          # default sans
fc-match 'sans-serif:lang=ja'                  # japanese sans
fc-match -s 'sans-serif:lang=ja'               # ordered list of
                                                # fallbacks

# install the noto family (covers nearly every script):
sudo dnf install google-noto-fonts-common \
    google-noto-sans-cjk-fonts \
    google-noto-serif-cjk-fonts \
    google-noto-emoji-fonts \
    google-noto-color-emoji-fonts

# per-user font preference ordering — controls which CJK font wins
# when the system font isn't enough:
mkdir -p ~/.config/fontconfig
cat > ~/.config/fontconfig/fonts.conf <<'EOF'
<?xml version="1.0"?>
<!DOCTYPE fontconfig SYSTEM "fonts.dtd">
<fontconfig>
  <!-- prefer japanese over chinese when language is ja -->
  <match target="pattern">
    <test name="lang" compare="contains"><string>ja</string></test>
    <edit name="family" mode="prepend">
      <string>Noto Sans CJK JP</string>
    </edit>
  </match>
  <!-- prefer simplified chinese -->
  <match target="pattern">
    <test name="lang" compare="contains"><string>zh-cn</string></test>
    <edit name="family" mode="prepend">
      <string>Noto Sans CJK SC</string>
    </edit>
  </match>
</fontconfig>
EOF
fc-cache -fv                                   # rebuild font cache


# THE "WRONG CJK FONT" PROBLEM

# the famous one: a japanese website renders in a chinese font,
# making characters look subtly wrong (kanji vs hanzi have different
# stroke conventions). this happens when fontconfig picks Noto Sans
# CJK SC (simplified chinese) for a page whose language tag is "ja"
# (japanese). the fix above makes the language tag actually drive
# the font choice.

# verify:
fc-match 'sans-serif:lang=ja'                  # should now say JP
fc-match 'sans-serif:lang=zh-cn'               # should say SC


