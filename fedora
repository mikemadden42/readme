#    automatic, but for the manually-paranoid:
flatpak override --user --filesystem=xdg-run/pipewire-0:ro \
    org.mozilla.firefox
# 4. you're on XWayland chromium (the Ozone flag — see ELECTRON below)


# MIGRATED TOOL NAMES — QUICK REFERENCE

#   X11 tool         wayland replacement
#   ────────────     ──────────────────────────────────────────────
#   xdotool          ydotool (kernel uinput; needs setup) or
#                    wtype (sway/wlroots only)
#   xrandr           wlr-randr (wlroots), kscreen-doctor (KDE),
#                    GNOME has no CLI — use Settings → Displays
#   xclip / xsel     wl-copy / wl-paste (from wl-clipboard)
#   xev              wev (wayland event viewer)
#   xprop            no direct replacement; window props aren't
#                    exposed to other clients
#   xkill            no replacement; killing other windows is not
#                    a wayland-native concept
#   xset s off       gsettings or busctl call to org.gnome.ScreenSaver
#   xrandr brightness  brightnessctl (kernel sysfs)
#   xdg-screensaver  busctl org.gnome.ScreenSaver (via dbus)


# YDOTOOL — XDOTOOL'S WAYLAND-COMPATIBLE COUSIN

# xdotool's input synthesis worked because X11 let any app inject
# events into any window. wayland doesn't. ydotool uses the kernel's
# uinput device instead — works regardless of display server.

sudo dnf install ydotool
sudo systemctl enable --now ydotoold
sudo usermod -aG input "$USER"                 # log out + back in

ydotool type "hello"
ydotool key 29:1 30:1 30:0 29:0                # Ctrl+A (keycodes)
ydotool mousemove --absolute 500 300


# WL-CLIPBOARD — XCLIP / XSEL'S WAYLAND COUSIN

sudo dnf install wl-clipboard

echo "hello" | wl-copy                         # copy to clipboard
wl-paste                                       # paste
wl-copy --primary < /etc/hostname              # primary selection
wl-paste --watch <command>                     # run command on clip changes


# GLOBAL HOTKEYS / CLIPBOARD MANAGERS / LAUNCHERS

# wayland doesn't let arbitrary clients grab system-wide keys. the
# COMPOSITOR has to grab them, then dispatch via D-Bus or a global
# shortcut framework. workarounds vary:
#
#   - GNOME: Settings → Keyboard → View and Customize Shortcuts.
#     add a custom shortcut → runs any command. enough for most
#     "launch my terminal on Ctrl+Alt+T".
#   - KDE: KGlobalAccel handles this natively (more flexible than
#     GNOME's UI).
#   - CLIPBOARD HISTORY: GNOME extension "gnome-clipboard-history" or
#     "Clipboard Indicator". for KDE, Klipper is built-in. for sway,
#     cliphist + wofi.
#   - LAUNCHERS: GNOME's Activities + search is the canonical answer;
#     rofi / wofi for wlroots compositors. ulauncher works on both
#     X11 and wayland (with caveats).


# WHAT STILL DOESN'T WORK CLEANLY

# 1. COLOR PICKERS that grab arbitrary pixels — XWayland-only. gcolor3
#    works via xdg-portal in some configs. for "what color is that"
#    quick checks: GNOME has "Color Picker" extension via xdg-portal.
#
# 2. SCREEN MAGNIFIERS / ACCESSIBILITY ZOOM — GNOME's built-in zoom
#    (Settings → Accessibility) works fine. third-party tools may not.
#
# 3. OBS SOURCE FILTERS that grab specific X11 windows — broken on
#    pure wayland. either capture the whole monitor or run OBS via
#    XWayland.
#
# 4. AUTOMATION TOOLS that watch arbitrary window state (AutoKey-style
#    text expanders, keyboard macro tools watching window class) —
#    limited. AT-SPI accessibility APIs are the modern path but
#    coverage is uneven.
#
# 5. SCREEN-SHARING VLC OUTPUT or specific app windows in older apps
#    that don't speak portals — fall back to XWayland or update the app.
#
# 6. SOME REMOTE-DESKTOP CLIENTS (TigerVNC viewer, x2go) — these
#    assume X11. GNOME's built-in "Remote Desktop" (Settings → Sharing)
#    speaks RDP and works fine over wayland.


# ELECTRON APPS + WAYLAND

# electron apps default to XWayland. they LOOK fine but you lose:
# fractional scaling, native window decoration, smooth touchpad
# gestures. force native wayland with the Ozone flag:
#
#   chromium / chrome / brave / vivaldi / opera:
#       --enable-features=UseOzonePlatform --ozone-platform=wayland
#   electron apps (vscode, slack, discord, signal, obsidian, etc.):
#       same flag works for most modern electron versions
#
# persistent for chrome via /etc/chromium-browser/default or a flag
# file. for vscode:
mkdir -p ~/.config
cat >> ~/.config/code-flags.conf <<'EOF'
--enable-features=UseOzonePlatform
--ozone-platform=wayland
EOF
#
# for flatpak electron apps, use Flatseal or `flatpak override`:
flatpak override --user --env=ELECTRON_OZONE_PLATFORM_HINT=auto \
    com.slack.Slack


# NVIDIA + WAYLAND STATUS

# cross-link to the NVIDIA section — short version: driver 545+ works
# well with wayland on GNOME and KDE. older driver branches struggle.
# if you're on akmod-nvidia from RPM Fusion, you're current.
