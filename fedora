# BLUETOOTH AUDIO — CODEC SELECTION

# bluetooth audio quality depends on the CODEC negotiated between
# device and host. ranked roughly best → worst:
#
#   LDAC          — sony's high-bitrate codec (~990 kbps). best for
#                   sony headphones; supported on linux.
#   aptX HD       — qualcomm's hi-res codec (576 kbps). many high-end
#                   non-sony headphones.
#   aptX          — qualcomm's standard codec (~352 kbps).
#   AAC           — apple's standard codec (~256 kbps).
#   SBC XQ        — high-bitrate SBC; widely compatible.
#   SBC           — the lowest-common-denominator codec. what you get
#                   if nothing else is negotiated.

# pipewire negotiates the best mutually-supported codec automatically.
# verify what you got:
pw-dump | grep -A2 'codec'                    # look for codec name
wpctl status                                   # bluetooth sink line

# force a specific codec for a device — edit wireplumber config:
sudo mkdir -p /etc/wireplumber/wireplumber.conf.d
sudo tee /etc/wireplumber/wireplumber.conf.d/51-bluez-codecs.conf <<'EOF'
monitor.bluez.properties = {
  bluez5.enable-sbc-xq        = true
  bluez5.enable-msbc          = true
  bluez5.enable-hw-volume     = true
  bluez5.codecs               = [ ldac aptx_hd aptx aac sbc_xq sbc ]
}
EOF
systemctl --user restart wireplumber pipewire pipewire-pulse

# common: "my $400 headphones sound terrible." 90% of the time the
# codec is SBC because bluez or wireplumber didn't enable the higher
# codecs. the above config fixes it.


